{
  "name": "anna.maria.dev",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "run-p dev:velite dev:next",
    "dev:next": "next dev",
    "dev:velite": "velite --watch",
    "build": "velite build && next build",
    "start": "next start",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "email:dev": "email dev --dir emails",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,mjs,cjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{css,json,md,mdx}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@react-email/components": "^1.0.12",
    "@vercel/og": "^0.11.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "motion": "^12.38.0",
    "next": "16.2.3",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-email": "^5.2.10",
    "resend": "^6.10.0",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "velite": "^0.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
